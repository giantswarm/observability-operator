logging {
	level  = "info"
	format = "logfmt"
}

remote.kubernetes.secret "credentials" {
	namespace = "kube-system"
	name = "{{ .SecretName }}"
}

{{- if .LoggingEnabled }}
// Kubernetes events source for Loki
loki.source.kubernetes_events "local" {
	{{- if and .IsWorkloadCluster .IncludeNamespaces }}
	namespaces = ["{{ join "\", \"" .IncludeNamespaces }}"]
	{{- else }}
	namespaces = []
	{{- end }}

	{{- if and .IsWorkloadCluster .ExcludeNamespaces }}
	forward_to = [loki.process.default.receiver]
	{{- else }}
	forward_to = [loki.write.default.receiver]
	{{- end }}
}

{{- if and .IsWorkloadCluster .ExcludeNamespaces }}
// Exclude configured namespaces from event logs
loki.process "default" {
	forward_to = [loki.write.default.receiver]

	stage.drop {
		source = "namespace"
		expression = {{ join "|" .ExcludeNamespaces | quote }}
	}
}
{{- end }}

// Loki target configuration
loki.write "default" {
	endpoint {
		max_backoff_period = "{{ .MaxBackoffPeriod }}"
		remote_timeout     = "{{ .RemoteTimeout }}"
		tenant_id          = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .LoggingTenantIDKey }}"])

		{{- if .IsWorkloadCluster }}
		url                = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .LoggingURLKey }}"])
		basic_auth {
			username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .LoggingUsernameKey }}"])
			password = remote.kubernetes.secret.credentials.data["{{ .LoggingPasswordKey }}"]
		}
		{{- else }}
		url                = "http://loki-gateway.loki.svc:80/loki/api/v1/push"
		{{- end }}

		tls_config {
			insecure_skip_verify = {{ .InsecureSkipVerify }}
		}
	}
	external_labels = {
		cluster_id       = "{{ .ClusterID }}",
		cluster_type     = "{{ .ClusterType }}",
		organization     = "{{ .Organization }}",
		provider         = "{{ .Provider }}",
		scrape_job       = "kubernetes-events",
	}
}
{{- end }}

{{- if or .TracingEnabled .OTLPMetricsEnabled .OTLPLogsEnabled }}
{{- if .TracingEnabled }}
// Basic authentication for Tempo
otelcol.auth.basic "tempo_credentials" {
	username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .TempoUsernameKey }}"])
	password = remote.kubernetes.secret.credentials.data["{{ .TempoPasswordKey }}"]
}
{{- end }}
{{- if and .IsWorkloadCluster .OTLPMetricsEnabled }}
// Basic authentication for Mimir
otelcol.auth.basic "mimir_credentials" {
	username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .MimirOTLPUsernameKey }}"])
	password = remote.kubernetes.secret.credentials.data["{{ .MimirOTLPPasswordKey }}"]
}
{{- end }}
{{- if and .OTLPLogsEnabled .IsWorkloadCluster }}
// Basic authentication for Loki
otelcol.auth.basic "loki_credentials" {
	username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .LokiOTLPUsernameKey }}"])
	password = remote.kubernetes.secret.credentials.data["{{ .LokiOTLPPasswordKey }}"]
}
{{- end }}

// OTLP receiver — accepts traces, metrics and logs from cluster workloads.
otelcol.receiver.otlp "default" {
	grpc {
		endpoint = "0.0.0.0:4317"
	}
	http {
		endpoint = "0.0.0.0:4318"
	}

	output {
		{{- if .TracingEnabled }}
		traces = [otelcol.processor.k8sattributes.default.input]
		{{- end }}
		{{- if .OTLPMetricsEnabled }}
		metrics = [otelcol.processor.k8sattributes.default.input]
		{{- end }}
		{{- if .OTLPLogsEnabled }}
		logs    = [otelcol.processor.k8sattributes.default.input]
		{{- end }}
	}
}

// Add Kubernetes metadata to all OTLP signals.
otelcol.processor.k8sattributes "default" {
	extract {
		metadata = [
			"k8s.namespace.name",
			"k8s.pod.name",
			"k8s.container.name",
		]
		label {
			key = "observability.giantswarm.io/tenant"
			tag_name = "giantswarm.tenant"
		}
		otel_annotations = true
	}

	output {
		{{- if .TracingEnabled }}
		traces = [otelcol.processor.transform.default.input]
		{{- end }}
		{{- if .OTLPMetricsEnabled }}
		metrics = [otelcol.processor.transform.default.input]
		{{- end }}
		{{- if .OTLPLogsEnabled }}
		logs    = [otelcol.processor.transform.default.input]
		{{- end }}
	}
}

// Add cluster metadata to traces, metrics and logs
otelcol.processor.transform "default" {
	error_mode = "ignore"

	{{- if .TracingEnabled }}
	trace_statements {
		context = "resource"
		statements = [
			`set(attributes["giantswarm.cluster.id"], "{{ .ClusterID }}")`,
			`set(attributes["giantswarm.cluster.type"], "{{ .ClusterType }}")`,
			`set(attributes["giantswarm.cluster.organization"], "{{ .Organization }}")`,
			`set(attributes["giantswarm.cluster.provider"], "{{ .Provider }}")`,
		]
	}
	{{- end }}
	{{- if .OTLPMetricsEnabled }}
	metric_statements {
		context = "resource"
		statements = [
			`set(attributes["giantswarm.cluster.id"], "{{ .ClusterID }}")`,
			`set(attributes["giantswarm.cluster.type"], "{{ .ClusterType }}")`,
			`set(attributes["giantswarm.cluster.organization"], "{{ .Organization }}")`,
			`set(attributes["giantswarm.cluster.provider"], "{{ .Provider }}")`,
		]
	}
	{{- end }}
	{{- if .OTLPLogsEnabled }}
	log_statements {
		context = "resource"
		statements = [
			`set(attributes["giantswarm.cluster.id"], "{{ .ClusterID }}")`,
			`set(attributes["giantswarm.cluster.type"], "{{ .ClusterType }}")`,
			`set(attributes["giantswarm.cluster.organization"], "{{ .Organization }}")`,
			`set(attributes["giantswarm.cluster.provider"], "{{ .Provider }}")`,
		]
	}
	{{- end }}

	output {
		{{- if .TracingEnabled }}
		traces = [otelcol.processor.batch.default.input]
		{{- end }}
		{{- if .OTLPMetricsEnabled }}
		metrics = [otelcol.processor.batch.default.input]
		{{- end }}
		{{- if .OTLPLogsEnabled }}
		logs    = [otelcol.processor.batch.default.input]
		{{- end }}
	}
}

// Batch processor for efficient export
otelcol.processor.batch "default" {
	send_batch_size     = {{ .OTLPBatchSendBatchSize }}
	send_batch_max_size = 0
	timeout             = "{{ .OTLPBatchTimeout }}"

	output {
		{{- if .TracingEnabled }}
		traces = [
			{{- range .Tenants }}
			otelcol.processor.filter.{{ . }}.input,
			{{- end }}
		]
		{{- end }}
		{{- if .OTLPMetricsEnabled }}
		metrics = [
			{{- range .Tenants }}
			otelcol.processor.filter.{{ . }}.input,
			{{- end }}
		]
		{{- end }}
		{{- if .OTLPLogsEnabled }}
		logs = [
			{{- range .Tenants }}
			otelcol.processor.filter.{{ . }}.input,
			{{- end }}
		]
		{{- end }}
	}
}

// Per-tenant routing
{{- range .Tenants }}
otelcol.processor.filter "{{ . }}" {
	{{- if $.TracingEnabled }}
	traces {
		span = [`resource.attributes["giantswarm.tenant"] != "{{ . }}"`]
	}
	{{- end }}
	{{- if $.OTLPMetricsEnabled }}
	metrics {
		datapoint = [`resource.attributes["giantswarm.tenant"] != "{{ . }}"`]
	}
	{{- end }}
	{{- if $.OTLPLogsEnabled }}
	logs {
		log_record = [
			`resource.attributes["giantswarm.tenant"] != "{{ . }}"`,
		]
	}
	{{- end }}
	output {
		{{- if $.TracingEnabled }}
		traces = [otelcol.exporter.otlp.{{ . }}_tempo.input]
		{{- end }}
		{{- if $.OTLPMetricsEnabled }}
		metrics = [otelcol.exporter.otlphttp.{{ . }}_mimir.input]
		{{- end }}
		{{- if $.OTLPLogsEnabled }}
		logs    = [otelcol.exporter.otlphttp.{{ . }}_loki.input]
		{{- end }}
	}
}

{{- if $.TracingEnabled }}
// OTLP gRPC exporter for traces — tenant {{ . }}
otelcol.exporter.otlp "{{ . }}_tempo" {
	client {
		{{- if $.IsWorkloadCluster }}
		auth     = otelcol.auth.basic.tempo_credentials.handler
		endpoint = "{{ $.TracingEndpoint }}"
		tls {
			insecure_skip_verify = false
		}
		{{- else }}
		tls {
			// Use insecure connection since this exporter uses a (direct) internal Tempo endpoint which is not behind a TLS reverse proxy.
			insecure = true
		}
		endpoint = "tempo-distributor.tempo.svc:4317"
		{{- end }}

		headers = {
			"X-Scope-OrgID" = "{{ . }}",
		}
	}
}
{{- end }}

{{- if $.OTLPMetricsEnabled }}
// OTLP HTTP exporter for metrics — tenant {{ . }} → Mimir
otelcol.exporter.otlphttp "{{ . }}_mimir" {
	client {
		{{- if $.IsWorkloadCluster }}
		auth     = otelcol.auth.basic.mimir_credentials.handler
		endpoint = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ $.MimirOTLPURLKey }}"])
		tls {
			insecure_skip_verify = false
		}
		{{- else }}
		endpoint = "http://mimir-gateway.mimir.svc:80/otlp"
		tls {
			insecure = true
		}
		{{- end }}

		headers = {
			"X-Scope-OrgID" = "{{ . }}",
		}
	}
}
{{- end }}

{{- if $.OTLPLogsEnabled }}
// OTLP HTTP exporter for logs — tenant {{ . }} → Loki
otelcol.exporter.otlphttp "{{ . }}_loki" {
	client {
		{{- if $.IsWorkloadCluster }}
		auth     = otelcol.auth.basic.loki_credentials.handler
		endpoint = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ $.LokiOTLPURLKey }}"])
		tls {
			insecure_skip_verify = false
		}
		{{- else }}
		endpoint = "http://loki-gateway.loki.svc:80/otlp"
		tls {
			insecure = true
		}
		{{- end }}

		headers = {
			"X-Scope-OrgID" = "{{ . }}",
		}
	}
}
{{- end }}

{{- end }}
{{- end }}
