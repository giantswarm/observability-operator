{{- /*
  promote_header_statements renders the statements array that copies giantswarm.tenant.from-header
  from the signal-level context up to resource attributes and removes it from the signal.
  Call with the OTTL context variable name as a string (e.g. "span", "datapoint", "log"):
    {{ template "promote_header_statements" "span" }}
*/ -}}
{{- define "promote_header_statements" -}}
    statements = [
      `set(resource.attributes["giantswarm.tenant.from-header"], {{ . }}.attributes["giantswarm.tenant.from-header"]) where {{ . }}.attributes["giantswarm.tenant.from-header"] != ""`,
      `delete_key({{ . }}.attributes, "giantswarm.tenant.from-header")`,
    ]
{{- end }}

{{- /*
  resource_statements renders the OTTL statements block shared by all three signal
  types (traces, metrics, logs) inside otelcol.processor.transform "default".
  It must be called with the top-level template data as its argument (dot).
*/ -}}
{{- define "resource_statements" -}}
    context = "resource"
    statements = [
      // Cluster metadata (OTel / k8s semantic conventions)
      `set(resource.attributes["k8s.cluster.name"], "{{ .ClusterID }}")`,
      `set(resource.attributes["k8s.cluster.type"], "{{ .ClusterType }}")`,
      `set(resource.attributes["k8s.cluster.organization"], "{{ .Organization }}")`,
      `set(resource.attributes["cloud.provider"], "{{ .Provider }}")`,
      // Tenant resolution — step 1: promote valid pod-label value
      {{- range .Tenants }}
      `set(resource.attributes["giantswarm.tenant"], "{{ . }}") where resource.attributes["giantswarm.tenant.from-label"] == "{{ . }}"`,
      {{- end }}
      // Tenant resolution — step 2: promote valid X-Scope-OrgID header (overrides label)
      {{- range .Tenants }}
      `set(resource.attributes["giantswarm.tenant"], "{{ . }}") where resource.attributes["giantswarm.tenant.from-header"] == "{{ . }}"`,
      {{- end }}
      // Tenant resolution — step 3: clean up temporary attributes
      `delete_key(resource.attributes, "giantswarm.tenant.from-label")`,
      `delete_key(resource.attributes, "giantswarm.tenant.from-header")`,
    ]
{{- end }}

logging {
  level  = "warn"
  format = "logfmt"
}

remote.kubernetes.secret "credentials" {
  namespace = "kube-system"
  name = "{{ .SecretName }}"
}

{{- if .LoggingEnabled }}
// Kubernetes events source for Loki
loki.source.kubernetes_events "default" {
  {{- if and .IsWorkloadCluster .IncludeNamespaces }}
  namespaces = ["{{ join "\", \"" .IncludeNamespaces }}"]
  {{- else }}
  namespaces = []
  {{- end }}

  {{- if and .IsWorkloadCluster .ExcludeNamespaces }}
  forward_to = [loki.process.default.receiver]
  {{- else }}
  forward_to = [otelcol.receiver.loki.events.receiver]
  {{- end }}
}

{{- if and .IsWorkloadCluster .ExcludeNamespaces }}
// Exclude configured namespaces from event logs
loki.process "default" {
  forward_to = [otelcol.receiver.loki.events.receiver]

  stage.drop {
    source = "namespace"
    expression = {{ join "|" .ExcludeNamespaces | quote }}
  }
}
{{- end }}

// Bridge Kubernetes events (Loki format) into the OTLP pipeline.
// loki.source.kubernetes_events emits Loki-format log entries; this receiver converts
// them to OTLP log records for downstream processing and export via otelcol.
otelcol.receiver.loki "events" {
  output {
    logs = [otelcol.processor.transform.events.input]
  }
}

// Set cluster metadata and tenant for Kubernetes events.
// Events always belong to the default tenant — unlike OTLP workload signals,
// they cannot carry a pod label or X-Scope-OrgID header, so the tenant is set directly.
otelcol.processor.transform "events" {
  error_mode = "ignore"

  log_statements {
    context = "resource"
    statements = [
      `set(resource.attributes["giantswarm.tenant"], "{{ .DefaultTenant }}")`,
      `set(resource.attributes["k8s.cluster.name"], "{{ .ClusterID }}")`,
      `set(resource.attributes["k8s.cluster.type"], "{{ .ClusterType }}")`,
      `set(resource.attributes["k8s.cluster.organization"], "{{ .Organization }}")`,
      `set(resource.attributes["cloud.provider"], "{{ .Provider }}")`,
    ]
  }

  output {
    logs = [otelcol.processor.batch.default.input]
  }
}
{{- end }}

{{- if or .TracingEnabled .MonitoringEnabled .LoggingEnabled }}
{{- if .TracingEnabled }}
// Basic authentication for Tempo
otelcol.auth.basic "tempo_credentials" {
  username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .TempoUsernameKey }}"])
  password = remote.kubernetes.secret.credentials.data["{{ .TempoPasswordKey }}"]
}
{{- end }}
{{- if .MonitoringEnabled }}
// Basic authentication for Mimir
otelcol.auth.basic "mimir_credentials" {
  username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .MimirUsernameKey }}"])
  password = remote.kubernetes.secret.credentials.data["{{ .MimirPasswordKey }}"]
}
{{- end }}
{{- if .LoggingEnabled }}
// Basic authentication for Loki
otelcol.auth.basic "loki_credentials" {
  username = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ .LoggingUsernameKey }}"])
  password = remote.kubernetes.secret.credentials.data["{{ .LoggingPasswordKey }}"]
}
{{- end }}

{{- if or .TracingEnabled .MonitoringEnabled .LoggingEnabled }}
{{- $signals := list -}}
{{- if .TracingEnabled }}{{- $signals = append $signals "traces" }}{{- end -}}
{{- if .MonitoringEnabled }}{{- $signals = append $signals "metrics" }}{{- end -}}
{{- if .LoggingEnabled }}{{- $signals = append $signals "logs" }}{{- end -}}
{{- $n := len $signals }}
// OTLP receiver — accepts
{{- if eq $n 1 }} {{ first $signals }}
{{- else if eq $n 2 }} {{ index $signals 0 }} and {{ index $signals 1 }}
{{- else }} {{ join ", " (initial $signals) }}, and {{ last $signals }}
{{- end }} from cluster workloads.
// include_metadata = true propagates HTTP headers and gRPC metadata to downstream
// processors, enabling the X-Scope-OrgID header to be used for tenant routing.
otelcol.receiver.otlp "default" {
  grpc {
    endpoint         = "0.0.0.0:4317"
    include_metadata = true
  }
  http {
    endpoint         = "0.0.0.0:4318"
    include_metadata = true
  }

  output {
    {{- if .TracingEnabled }}
    traces = [otelcol.processor.k8sattributes.default.input]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [otelcol.processor.k8sattributes.default.input]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [otelcol.processor.k8sattributes.default.input]
    {{- end }}
  }
}

// Add Kubernetes metadata to all OTLP signals.
// The tenant pod label is extracted to giantswarm.tenant.from-label (a temporary
// attribute) rather than directly to giantswarm.tenant; validation and final
// assignment happen in the transform processor below.
otelcol.processor.k8sattributes "default" {
  extract {
    metadata = [
      "k8s.namespace.name",
      "k8s.pod.name",
      "k8s.container.name",
    ]
    label {
      key      = "observability.giantswarm.io/tenant"
      tag_name = "giantswarm.tenant.from-label"
    }
    otel_annotations = true
  }

  output {
    {{- if .TracingEnabled }}
    traces = [otelcol.processor.attributes.extract_tenant_header.input]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [otelcol.processor.attributes.extract_tenant_header.input]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [otelcol.processor.attributes.extract_tenant_header.input]
    {{- end }}
  }
}

// Extract the X-Scope-OrgID request header into signal attributes.
// The header is normalized by the receiver to metadata.x-scope-orgid.
otelcol.processor.attributes "extract_tenant_header" {
  action {
    key          = "giantswarm.tenant.from-header"
    action       = "insert"
    from_context = "metadata.x-scope-orgid"
  }

  output {
    {{- if .TracingEnabled }}
    traces = [otelcol.processor.transform.promote_header_to_resource.input]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [otelcol.processor.transform.promote_header_to_resource.input]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [otelcol.processor.transform.promote_header_to_resource.input]
    {{- end }}
  }
}

// Promote signal-level header attribute to resource attributes.
// The attributes processor adds giantswarm.tenant.from-header at the signal level (span/log/metric).
// This transform copies it to resource.attributes where tenant resolution can access it.
otelcol.processor.transform "promote_header_to_resource" {
  error_mode = "ignore"

  {{- if .TracingEnabled }}
  trace_statements {
    context = "span"
    {{ template "promote_header_statements" "span" }}
  }
  {{- end }}
  {{- if .MonitoringEnabled }}
  metric_statements {
    context = "datapoint"
    {{ template "promote_header_statements" "datapoint" }}
  }
  {{- end }}
  {{- if .LoggingEnabled }}
  log_statements {
    context = "log"
    {{ template "promote_header_statements" "log" }}
  }
  {{- end }}

  output {
    {{- if .TracingEnabled }}
    traces = [otelcol.processor.transform.default.input]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [otelcol.processor.transform.default.input]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [otelcol.processor.transform.default.input]
    {{- end }}
  }
}

// Add cluster metadata and resolve giantswarm.tenant for all OTLP signals.
//
// Tenant resolution:
//   1. Label extraction  — giantswarm.tenant.from-label (set by k8sattributes from
//      the pod label observability.giantswarm.io/tenant) is already in resource attributes
//   2. Header extraction — giantswarm.tenant.from-header (promoted from signal attributes by
//      the promote_header_to_resource transform) is in resource attributes
//   3. Header promotion  — giantswarm.tenant.from-header is promoted to giantswarm.tenant
//      only if the value matches an accepted tenant, overriding any label-derived value.
//   4. Label promotion   — giantswarm.tenant.from-label is promoted to giantswarm.tenant
//      only if the value matches an accepted tenant (and header was not matched).
//   5. Cleanup — both temporary attributes are removed.
//
// Invalid, empty, or absent values from either source are never promoted, so signals
// whose tenant cannot be resolved are dropped by the per-tenant filter processors.
otelcol.processor.transform "default" {
  error_mode = "ignore"

  {{- if .TracingEnabled }}
  trace_statements {
    {{ template "resource_statements" . }}
  }
  {{- end }}
  {{- if .MonitoringEnabled }}
  metric_statements {
    {{ template "resource_statements" . }}
  }
  {{- end }}
  {{- if .LoggingEnabled }}
  log_statements {
    {{ template "resource_statements" . }}
  }
  {{- end }}

  output {
    {{- if .TracingEnabled }}
    traces = [otelcol.processor.batch.default.input]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [otelcol.processor.batch.default.input]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [otelcol.processor.batch.default.input]
    {{- end }}
  }
}
{{- end }}

// Batch processor for efficient export.
// send_batch_max_size caps the number of items per export call, preventing individual
// gRPC messages from exceeding the server's 4 MB decompressed message size limit.
// Both size fields are set to the same value so batch semantics are simple and predictable:
// flush when send_batch_max_size items are queued, or when timeout elapses.
otelcol.processor.batch "default" {
  send_batch_size     = {{ .OTLPBatchSendBatchSize }}
  send_batch_max_size = {{ .OTLPBatchMaxSize }}
  timeout             = "{{ .OTLPBatchTimeout }}"

  output {
    {{- if .TracingEnabled }}
    traces = [
      {{- range .Tenants }}
      otelcol.processor.filter.{{ . }}.input,
      {{- end }}
    ]
    {{- end }}
    {{- if .MonitoringEnabled }}
    metrics = [
      {{- range .Tenants }}
      otelcol.processor.filter.{{ . }}.input,
      {{- end }}
    ]
    {{- end }}
    {{- if .LoggingEnabled }}
    logs = [
      {{- range .Tenants }}
      otelcol.processor.filter.{{ . }}.input,
      {{- end }}
    ]
    {{- end }}
  }
}

// Per-tenant routing
{{- range .Tenants }}
otelcol.processor.filter "{{ . }}" {
  {{- if $.TracingEnabled }}
  traces {
    span = [`resource.attributes["giantswarm.tenant"] != "{{ . }}"`]
  }
  {{- end }}
  {{- if $.MonitoringEnabled }}
  metrics {
    datapoint = [`resource.attributes["giantswarm.tenant"] != "{{ . }}"`]
  }
  {{- end }}
  {{- if $.LoggingEnabled }}
  logs {
    log_record = [`resource.attributes["giantswarm.tenant"] != "{{ . }}"`]
  }
  {{- end }}

  output {
    {{- if $.TracingEnabled }}
    traces = [otelcol.exporter.otlp.{{ . }}_tempo.input]
    {{- end }}
    {{- if $.MonitoringEnabled }}
    metrics = [otelcol.exporter.otlphttp.{{ . }}_mimir.input]
    {{- end }}
    {{- if $.LoggingEnabled }}
    logs = [otelcol.exporter.otlphttp.{{ . }}_loki.input]
    {{- end }}
  }
}

{{- if $.TracingEnabled }}
// OTLP gRPC exporter for traces — tenant {{ . }} → Tempo
otelcol.exporter.otlp "{{ . }}_tempo" {
  client {
    auth     = otelcol.auth.basic.tempo_credentials.handler
    endpoint = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ $.TempoEndpointKey }}"])
    tls {
      insecure_skip_verify = false
    }

    headers = {
      "X-Scope-OrgID" = "{{ . }}",
    }
  }
}
{{- end }}

{{- if $.MonitoringEnabled }}
// OTLP HTTP exporter for metrics — tenant {{ . }} → Mimir
// Mimir's distributor is configured with -distributor.otel-promote-resource-attributes
// to automatically promote resource attributes (cluster metadata) to metric labels.
otelcol.exporter.otlphttp "{{ . }}_mimir" {
  client {
    auth     = otelcol.auth.basic.mimir_credentials.handler
    endpoint = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ $.MimirOTLPURLKey }}"])
    tls {
      insecure_skip_verify = false
    }

    headers = {
      "X-Scope-OrgID" = "{{ . }}",
    }
  }
}
{{- end }}

{{- if $.LoggingEnabled }}
// OTLP HTTP exporter for logs — tenant {{ . }} → Loki
otelcol.exporter.otlphttp "{{ . }}_loki" {
  client {
    auth     = otelcol.auth.basic.loki_credentials.handler
    endpoint = convert.nonsensitive(remote.kubernetes.secret.credentials.data["{{ $.LokiOTLPURLKey }}"])
    tls {
      insecure_skip_verify = false
    }

    headers = {
      "X-Scope-OrgID" = "{{ . }}",
    }
  }
}
{{- end }}

{{- end }}
{{- end }}
