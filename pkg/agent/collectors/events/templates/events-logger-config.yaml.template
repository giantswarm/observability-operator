# This file was generated by observability-operator.
{{- if and .LoggingEnabled .TracingEnabled }}
# It configures Alloy for events logging and tracing.
{{- else if .LoggingEnabled }}
# It configures Alloy for events logging.
{{- else if .TracingEnabled }}
# It configures Alloy for tracing.
{{- else if .OTLPMetricsEnabled }}
# It configures Alloy for OTLP metrics ingestion.
{{- else if .OTLPLogsEnabled }}
# It configures Alloy for OTLP logs ingestion.
{{- end }}
# - configMap is generated from events-logger.alloy.template and passed as a string
#   here and will be created by Alloy's chart.
# - Alloy runs as a deployment, with only 1 replica.
{{- if or .TracingEnabled .OTLPMetricsEnabled .OTLPLogsEnabled .LoggingEnabled }}
networkPolicy:
  cilium:
    egress:
    - toEntities:
      - kube-apiserver
      - cluster # (needed for access to the gateway)
      - world
    # Allow DNS resolution
    - toEndpoints:
      - matchLabels:
          k8s-app: coredns
      - matchLabels:
          k8s-app: k8s-dns-node-cache
      toPorts:
      - ports:
        - port: "53"
          protocol: ANY
        - port: "1053"
          protocol: ANY
        rules:
          dns:
            - matchPattern: '*'
    {{- if or .TracingEnabled .OTLPMetricsEnabled .OTLPLogsEnabled }}
    ingress:
    - toPorts:
      - ports:
        # Alloy UI and API
        - port: "12345"
          protocol: TCP
        # OTLP gRPC receiver
        - port: "4317"
          protocol: "TCP"
        # OTLP HTTP receiver
        - port: "4318"
          protocol: "TCP"
    {{- end }}
{{- end }}

alloy:
  alloy:
    configMap:
      create: true
      content: |-
        {{ .AlloyConfig | nindent 8 | replace "        \n" "" | trim }}
    # Resource configuration based on https://github.com/giantswarm/giantswarm/issues/32655
    # CPU limits updated in https://github.com/giantswarm/giantswarm/issues/34619 to prevent throttling
    resources:
      limits:
        cpu: 500m
        memory: 256Mi
      requests:
        cpu: 50m
        memory: 128Mi
    securityContext:
      allowPrivilegeEscalation: false
      capabilities:
        drop:
        - ALL
      readOnlyRootFilesystem: false
      runAsUser: 10
      runAsGroup: 10
      runAsNonRoot: true
      seccompProfile:
        type: RuntimeDefault
  controller:
    type: deployment
    replicas: 1
  crds:
    create: false

  {{- if or .TracingEnabled .OTLPMetricsEnabled .OTLPLogsEnabled }}
  extraObjects:
  # OTLP gateway service for traces, metrics and logs
  - apiVersion: v1
    kind: Service
    metadata:
      annotations:
        meta.helm.sh/release-name: alloy-events
        meta.helm.sh/release-namespace: kube-system
      labels:
        app.kubernetes.io/component: networking
        app.kubernetes.io/instance: alloy-events
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: alloy
        app.kubernetes.io/part-of: alloy
        application.giantswarm.io/team: atlas
        giantswarm.io/managed-by: alloy-events
        giantswarm.io/service-type: managed
        helm.sh/chart: alloy-1.1.0
      name: otlp-gateway
      namespace: kube-system
    spec:
      ports:
      - appProtocol: grpc
        name: otlp
        port: 4317
        protocol: TCP
        targetPort: 4317
      - appProtocol: http
        name: otlp-http
        port: 4318
        protocol: TCP
        targetPort: 4318
      selector:
        app.kubernetes.io/instance: alloy-events
        app.kubernetes.io/name: alloy
      type: ClusterIP
  {{- end }}

verticalPodAutoscaler:
  enabled: true
  # VPA configuration based on https://github.com/giantswarm/giantswarm/issues/32655
  resourcePolicy:
    containerPolicies:
    - containerName: alloy
      controlledResources:
      - memory
      controlledValues: "RequestsAndLimits"
